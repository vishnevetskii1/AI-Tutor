# ── Telegram ──────────────────────────────────────────────
# Получить у @BotFather в Telegram
TELEGRAM_BOT_TOKEN=your_token_here

# ── Google AI API ──────────────────────────────────────────
# Получить бесплатно на https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_key_here

# ── OpenRouter API ─────────────────────────────────────────
# Получить на https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=your_openrouter_key_here

# ── LLM провайдер ─────────────────────────────────────────
# google  — Google AI API
# openrouter — OpenRouter SDK/API
# ollama  — локальная модель через Ollama
LLM_PROVIDER=ollama

# ── Модель генерации ──────────────────────────────────────
# Для OpenRouter, например: google/gemini-2.5-flash
# Для Google, например: models/gemini-2.0-flash
LLM_MODEL=google/gemini-2.5-flash
EMBEDDING_MODEL=nomic-embed-text

# ── Ollama (если LLM_PROVIDER=ollama) ────────────────────
# Для Docker Compose со всем стеком = http://ollama:11434
# Для локального запуска вне Docker = http://localhost:11434
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:3b
LLM_FALLBACK_TO_GOOGLE=false
OLLAMA_TIMEOUT_SECONDS=120

# ── Qdrant ────────────────────────────────────────────────
# В Docker Compose автоматически = http://qdrant:6333
# Для локальной разработки = http://localhost:6333
QDRANT_URL=http://localhost:6333

# ── База данных SQLite ────────────────────────────────────
SQLITE_PATH=data/tutor.db

# ── Папка с PDF учебниками ────────────────────────────────
# Структура: data/disciplines/{slug}/*.pdf
# Например:  data/disciplines/math/учебник.pdf
DISCIPLINES_DIR=data/disciplines
